#!/bin/bash
# tacape pre-commit hook. Install with: bash hooks/install-git-hooks.sh
#
# Blocks a commit that would introduce a U+2014 em dash into prose or UI copy. The PreToolUse guard
# covers what the agent writes through its tools; this covers everything else that reaches the
# index, which is the gap the guard cannot see.
#
# Same target as the guard, deliberately: em dash only, prose files only. A rule enforced at two
# layers with two different definitions is two rules, and the looser layer teaches people to
# ignore the stricter one.

# Extensions a human reads as prose or as UI copy. Anything else is skipped.
PROSE='\.(md|mdx|markdown|txt|rst|html?|jsx|tsx|vue|svelte|astro)$'

STAGED=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$STAGED" ] && exit 0

FOUND=""
while IFS= read -r f; do
  [ -f "$f" ] || continue
  printf '%s' "$f" | grep -qE "$PROSE" || continue
  # -I skips binary files. A .html served as a binary blob is still not prose to fix, and a
  # binary's bytes match the pattern by coincidence, so a hit there is always a false positive.
  if grep -lIP '\x{2014}' "$f" >/dev/null 2>&1; then
    FOUND="$FOUND  $f"$'\n'
  fi
done <<< "$STAGED"

if [ -n "$FOUND" ]; then
  printf 'Blocked by tacape: U+2014 em dash in staged prose files:\n'
  printf '%s' "$FOUND"
  printf 'Replace with a comma, a colon, a period, or a real hyphen "-".\n'
  printf 'To override once: git commit --no-verify\n'
  exit 1
fi

exit 0
