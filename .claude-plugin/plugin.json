{
  "name": "tacape",
  "description": "Action-first output, Caveman-style compression, and opinionated engineering rules for AI coding agents. Optional write-time em dash guard.",
  "version": "0.3.0",
  "author": {
    "name": "Mateus Satoh",
    "url": "https://github.com/mateussatoh"
  },
  "homepage": "https://github.com/mateussatoh/tacape",
  "repository": "https://github.com/mateussatoh/tacape",
  "license": "MIT",
  "keywords": [
    "productivity",
    "brevity",
    "adhd",
    "code-style",
    "code-review"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/tacape-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading tacape..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/tacape-emdash-guard.js\"",
            "timeout": 5,
            "statusMessage": "Checking for em dash..."
          }
        ]
      }
    ]
  }
}
